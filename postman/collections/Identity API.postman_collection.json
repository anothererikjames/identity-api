    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set(\"newUserEmail\",`test-${Date.now()}@acme.io`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201\",()=>pm.response.to.have.status(201));",
                  "pm.test(\"Returns user id\",()=>{const b=pm.response.json();",
                  "  pm.expect(b.id).to.be.a(\"string\");",
                  "  pm.environment.set(\"userId\",b.id);});",
                  "pm.test(\"Returns email\",()=>pm.expect(pm.response.json().email).to.be.a(\"string\").and.not.empty);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
