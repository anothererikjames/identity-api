                  "key": "token",
                  "value": "{{accessToken}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{newUserEmail}}\",\"password\":\"Acme@Secure123!\",\"name\":\"Test User\"}"
            }
